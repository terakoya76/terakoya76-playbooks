  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "memory",
    "sequential-thinking",
    "context7",
    "deepwiki",
    "playwright"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Write|Edit|Bash|Grep|mcp__serena__read_file|mcp__serena__search_for_pattern|mcp__serena__find_file|mcp__serena__list_dir",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/.claude/hooks/secret_guard.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "uv run ~/.claude/hooks/task_medium_prep_hook.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.message' | xargs -I {} ~/.claude/hooks/notify_slack.sh '{}'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify_slack.sh 'Complete the whole task'"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "theme": "dark"
}
